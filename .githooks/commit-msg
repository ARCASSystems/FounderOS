#!/usr/bin/env bash
set -e
# Probe by RUNNING each candidate (same order as setup's preflight: python,
# python3, py -3). `command -v` alone is not enough on Windows, where the
# Microsoft Store ships stub python/python3 executables that exist but cannot
# run, and machines with only the py launcher have no python3 at all.
GUARD="$(git rev-parse --show-toplevel)/scripts/check-private-names.py"
if python --version >/dev/null 2>&1; then
  exec python "$GUARD" --message "$1"
elif python3 --version >/dev/null 2>&1; then
  exec python3 "$GUARD" --message "$1"
elif py -3 --version >/dev/null 2>&1; then
  exec py -3 "$GUARD" --message "$1"
fi
# No working Python: graceful no-op by design (never break `git commit`).
exit 0
