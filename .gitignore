# Founder OS Product - gitignore

# Generated by setup wizard (user-specific)
core/identity.md
context/priorities.md
context/decisions.md
context/clients.md
context/companies.md
cadence/daily-anchors.md
cadence/weekly-commitments.md
brain/log.md
brain/flags.md
brain/patterns.md
brain/decisions-parked.md
brain/archive/
brain/.snapshot.md
brain/rants/
brain/knowledge/
brain/needs-input.md
clients/
user/
drafts/
exports/
reports/

# Stack bindings (user fills these in during setup - not shareable as-is)
# Committed as template with placeholders. User's filled version is private.

# Secrets
.env
.env.*
*.key

# Connector status (per-user state written by the `connect` skill; NO secrets,
# but machine-specific - the connect skill regenerates it. Secrets stay in .env.)
connectors/

# Local Claude settings (per-user, not shareable)
CLAUDE.local.md
AGENTS.local.md
GEMINI.local.md
.mcp.local.json
.claude/settings.local.json
.codex/
.gemini/

# OS + editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Obsidian vault config (per-user, not shareable; Obsidian writes this when the founder-os folder is opened as a vault)
.obsidian/

# Build artifacts (none expected, just in case)
dist/
build/
node_modules/

# Test suite (dev-only; removed from public repo in v1.28, kept locally for the maintainer)
tests/
.pytest_cache/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Audit artifacts (generated, not source-of-truth)
audit-*.md

# Internal review notes (Codex findings, verification logs, working memory)
# Kept locally for reference. Not committed to the public repo. The v1.7 notes
# that were previously grandfathered in were untracked 2026-06-05.
notes/

# Public playbook build/workbench artifacts.
# The playbooks now live on the web (arcassystems.com/playbook); the public repo
# ships no rendered playbook HTML. These build artifacts stay local when present.
skills.html
playbook.html
playbook.template.html
playbook.manifest.json
founder-os-playbook.html
the-second-brain-playbook.html
scripts/screenshot-playbook.py

# Archived playbook version snapshots. Kept locally for review, never shipped.
# The rendered playbooks live on the web, not in this repo; every prior
# version-tagged copy lives here, out of the tracked tree.
/archive/

# Execution plans (internal release scaffolding - Codex reads locally, never commits)
plans/

# Evaluation traces (synthetic user sessions / dev-QA artifacts, not product code).
# Dev-only, never shipped. The v1.21 traces previously committed as "product evidence"
# were untracked 2026-06-05; the whole dir stays local now.
traces/

# Agent runner scratch directory (dev tooling, not product code)
.agents/

# Operator-local private-name patterns for pre-commit hook (gitignored; template is tracked)
scripts/private-name-patterns.txt

# Public-facing roadmap removed from the public repo on 2026-05-18.
# CHANGELOG.md is now the single source of truth for what shipped; release notes
# and "what we deliberately did not build" rationale live in CHANGELOG.md and
# docs/forking.md respectively. Keep the file gitignored so a re-created local
# ROADMAP.md does not accidentally land back in the public repo.
ROADMAP.md
